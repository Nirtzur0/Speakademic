{
  "manifest_version": 3,
  "name": "Speakademic",
  "version": "0.3.0",
  "description": "Read academic papers and articles aloud with AI text-to-speech",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "offscreen"
  ],

  "host_permissions": [
    "http://localhost:8880/*",
    "http://127.0.0.1:8880/*",
    "http://localhost:3000/*",
    "https://api.speakademic.com/*",
    "https://arxiv.org/*",
    "https://*.arxiv.org/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "toggle-playback": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Play or pause reading"
    },
    "stop-playback": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Stop reading"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.mjs",
        "options/success.html",
        "options/cancel.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
